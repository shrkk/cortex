# Database
# App uses asyncpg driver — must use postgresql+asyncpg:// scheme
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex
# Alembic migration runner is synchronous — must use postgresql:// scheme (psycopg2)
DATABASE_URL_SYNC=postgresql://cortex:cortex@localhost:5432/cortex

# External APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# App
ENVIRONMENT=development
